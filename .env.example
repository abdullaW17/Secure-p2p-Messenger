# I2I Environment Variables
# Copy this file to .env and adjust values as needed.
# NEVER commit your .env file to version control.

# Port to listen for incoming peer connections
I2I_LISTEN_PORT=7777

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
I2I_LOG_LEVEL=INFO

# Maximum file size allowed for transfer (in MB)
I2I_MAX_FILE_MB=50

# Maximum chat message size (in KB)
I2I_MAX_MSG_KB=4

# Admin Role Verification
# Enter this code in the GUI when registering an account with username 'admin'
I2I_ADMIN_SECRET=YOUR_SECRET_CODE_HERE
